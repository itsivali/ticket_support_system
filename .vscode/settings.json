{
    "dart.flutterRunAdditionalArgs": [
        "-d",
        "chrome",
        "--web-port=3001",
        "--web-browser-flag=--disable-web-security"
    ],
    "dart.previewFlutterUiGuides": true,
    "cmake.sourceDirectory": "${workspaceFolder}/linux/flutter",
    "dart.env": {
        "CHROME_EXECUTABLE": "/usr/bin/google-chrome-stable"
    }
}